{
  "rules": {
    "alerts": {
      ".read": true,
      "$alertId": {
        "status": {
          ".write": "data.parent().exists() && newData.isString() && (newData.val() === 'new' || newData.val() === 'investigating' || newData.val() === 'resolved')",
          ".validate": "newData.isString() && (newData.val() === 'new' || newData.val() === 'investigating' || newData.val() === 'resolved')"
        }
      }
    }
  }
}
